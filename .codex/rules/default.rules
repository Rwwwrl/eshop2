# ============================================================
# Project rules — mirrors .claude/settings.local.json
# ============================================================

# Git (allow)
prefix_rule(["git", "status"], decision="allow")
prefix_rule(["git", "diff"], decision="allow")
prefix_rule(["git", "log"], decision="allow")
prefix_rule(["git", "add"], decision="allow")
prefix_rule(["git", "commit"], decision="allow")
prefix_rule(["git", "push"], decision="allow")
prefix_rule(["git", "branch"], decision="allow")
prefix_rule(["git", "mv"], decision="allow")

# GitHub CLI (allow)
prefix_rule(["gh", "pr", "create"], decision="allow")
prefix_rule(["gh", "pr", "view"], decision="allow")

# Python tooling (allow)
prefix_rule(["poetry"], decision="allow")

# Kubernetes (allow)
prefix_rule(["kustomize", "build"], decision="allow")
prefix_rule(["kubectl", "kustomize"], decision="allow")
prefix_rule(["kubectl", "get"], decision="allow")
prefix_rule(["kubectl", "describe"], decision="allow")
prefix_rule(["kubectl", "logs"], decision="allow")

# Infrastructure (allow)
prefix_rule(["curl"], decision="allow")
prefix_rule(["helm", "list"], decision="allow")
